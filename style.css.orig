* {
  background-color: #111;
  color: #ddd;
  font-family: monospace;
  margin: 32px 0;
}

h1 {
  font-size: 32px;
  padding-top: 32px;
  margin-top: 0;
}

h2 {
  font-size: 28px;
  margin-bottom: 8px;
}

.hr-right {
  border: none;
  border-top: 1px solid #333;
  margin: 18px 40% 24px auto;
}

.hr-left {
  border: none;
  border-top: 1px solid #333;
  margin: 18px auto 24px 40%;
}

.vl {
  border-left: 1px solid #333;
  height: 100%;
  position: absolute;
  left: 50%;
  margin-left: -0.5px;
  top: 0;
  transition: height 1.0s;
  animation: growDown 1.0s ease-out forwards;
  transform-origin: top;
}

@keyframes growDown {
  0% {
    transform: scaleY(0);
  }

  100% {
    transform: scaleY(1);
  }
}

#right-content {
  margin-left: 52%;
  position: relative;
}

#head-image-container {
  position: relative;
  width: 100%;
  animation: fadeFromRight 1.0s ease-out forwards;
}

#head-image {
  position: absolute;
  width: 12%;
  right: 52%;
  border-radius: 32px;
  transition: all 0.5s;
  animation: fadeFromRight 0.5s ease-out forwards;
}

@keyframes fadeFromRight {

  0% {
    transform: translate(2%, -100px) scale(0.7);
    opacity: 0;
  }

  100% {
    transform: translate(0, 0) scale(1);
    opacity: 1;
  }
}

.right-container {
  position: relative;
  width: 100%;
}

.right-element {
  margin-bottom: 0px;
  padding-right: 40%;
}

#projects-head-container {
  margin-bottom: 0;
}

#cycling-header {
  margin: 0;
