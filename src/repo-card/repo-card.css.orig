.repo-head {
  margin: 20px 0 0 20px;
  font-family: sans-serif;
  font-weight: bold;
  font-size: 16px;
  color: #DDD;
  background-color: transparent;
}

.repo-desc-stars {
  margin: 0;
  display: flex;
  justify-content: space-between;
  background-color: transparent;
  position: absolute;
  bottom: 10px;
  left: 0;
  right: 0;
}

.repo-desc {
  font-family: sans-serif;
  font-size: 14px;
  margin: 20px 0 10px 20px;
  width: 80%;
  color: #999;
  background-color: transparent;
}

.repo-stars {
  font-family: sans-serif;
  font-size: 14px;
  margin: 20px 20px 10px 0;
  white-space: nowrap;
  text-align: right;
  color: #BBB;
  background-color: transparent;
  justify-content: flex-end;
  align-content: flex-end;
}

.disabled-link {
  pointer-events: none;
}
