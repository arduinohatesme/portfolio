repo-card:not([enabled]) * {
  background: transparent;
  border: transparent;
  color: transparent;
}

repo-card[enabled] {
  background-color: #222;
}

repo-card:hover[enabled] {
  box-sizing: content-box;
  background-color: #333;
  transform: translate(-8px, -8px);
  box-shadow:
    8px 8px 8px #000;
}

